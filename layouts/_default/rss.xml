{{- $pctx := . -}}
{{- if .IsHome -}}{{ $pctx = .Site }}{{- end -}}
{{- $pages := slice -}}
{{- if or $.IsHome $.IsSection -}}
{{- $pages = $pctx.RegularPages -}}
{{- else -}}
{{- $pages = $pctx.Pages -}}
{{- end -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
{{- $pages = $pages | first $limit -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"
  xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd"
  xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Site.Params.description }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.Language.Lang }}</language>
    {{ with .Site.Params.author }}<itunes:author>{{ . }}</itunes:author>{{ end }}
    {{ with .Site.Params.description }}<itunes:summary>{{ . }}</itunes:summary>{{ end }}
    {{- if .Site.Copyright }}
    <copyright>{{ .Site.Copyright }}</copyright>
    {{- end }}
    <lastBuildDate>{{ (index $pages 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    {{ range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Summary | html }}</description>
      {{- with .Content }}
      <content:encoded>{{ . | html }}</content:encoded>
      {{- end }}
      {{- with .Params.audio_url }}
      <enclosure url="{{ . | absURL }}" type="audio/mpeg"
        {{- with $.Params.audio_length }} length="{{ . }}"{{ end }}/>
      {{- end }}
      {{- with .Params.duration }}
      <itunes:duration>{{ . }}</itunes:duration>
      {{- end }}
      {{- range .Params.tags }}
      <category>{{ . }}</category>
      {{- end }}
    </item>
    {{ end }}
  </channel>
</rss>
